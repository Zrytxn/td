<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IRON BASTION — Tower Defence</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050a0f;
    --panel: #0a1520;
    --panel2: #0d1e2e;
    --border: #1a3a5c;
    --accent: #00d4ff;
    --accent2: #ff6b00;
    --accent3: #00ff88;
    --danger: #ff2244;
    --gold: #ffd700;
    --text: #c8e8ff;
    --dim: #4a7a9b;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── HEADER ── */
  #header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  #header h1 {
    font-family: 'Orbitron', monospace;
    font-size: 18px;
    font-weight: 900;
    letter-spacing: 4px;
    color: var(--accent);
    text-shadow: 0 0 20px var(--accent);
  }
  .stat-block { display: flex; gap: 20px; align-items: center; }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat-label { font-size: 9px; color: var(--dim); letter-spacing: 2px; }
  .stat-value { font-family: 'Orbitron', monospace; font-size: 16px; font-weight: 700; }
  #lives-val { color: var(--danger); text-shadow: 0 0 10px var(--danger); }
  #gold-val { color: var(--gold); text-shadow: 0 0 10px var(--gold); }
  #wave-val { color: var(--accent); }
  #score-val { color: var(--accent3); text-shadow: 0 0 10px var(--accent3); }

  /* ── MAIN LAYOUT ── */
  #game-area {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  /* ── CANVAS ── */
  #canvas-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background: var(--bg);
    overflow: hidden;
  }
  canvas {
    display: block;
    cursor: crosshair;
    image-rendering: pixelated;
  }

  /* ── SIDE PANEL ── */
  #side-panel {
    width: 200px;
    background: var(--panel);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow-y: auto;
    flex-shrink: 0;
  }
  .panel-section {
    border-bottom: 1px solid var(--border);
    padding: 10px;
  }
  .panel-title {
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--dim);
    margin-bottom: 8px;
  }

  /* Tower cards */
  .tower-card {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 8px;
    border: 1px solid var(--border);
    border-radius: 3px;
    margin-bottom: 5px;
    cursor: pointer;
    transition: all 0.15s;
    background: var(--panel2);
    position: relative;
  }
  .tower-card:hover { border-color: var(--accent); background: #0e2030; }
  .tower-card.selected { border-color: var(--accent); box-shadow: 0 0 8px var(--accent); background: #0e2030; }
  .tower-card.too-expensive { opacity: 0.4; cursor: not-allowed; }
  .tower-icon { width: 28px; height: 28px; flex-shrink: 0; }
  .tower-info { flex: 1; }
  .tower-name { font-size: 10px; color: var(--text); font-family: 'Orbitron', monospace; }
  .tower-cost { font-size: 10px; color: var(--gold); }
  .tower-desc { font-size: 8px; color: var(--dim); margin-top: 2px; line-height: 1.3; }

  /* Selected tower info */
  #selected-info { padding: 10px; border-bottom: 1px solid var(--border); display: none; }
  #selected-info.visible { display: block; }
  .info-row { display: flex; justify-content: space-between; font-size: 10px; margin-bottom: 4px; }
  .info-row span:first-child { color: var(--dim); }
  .info-row span:last-child { color: var(--text); }
  #upgrade-btn, #sell-btn {
    width: 100%;
    padding: 6px;
    border: 1px solid;
    background: transparent;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    cursor: pointer;
    letter-spacing: 1px;
    margin-top: 4px;
    transition: all 0.15s;
  }
  #upgrade-btn { border-color: var(--accent3); color: var(--accent3); }
  #upgrade-btn:hover { background: var(--accent3); color: var(--bg); }
  #upgrade-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  #sell-btn { border-color: var(--danger); color: var(--danger); }
  #sell-btn:hover { background: var(--danger); color: white; }

  /* Buttons */
  #start-wave-btn {
    margin: 10px;
    padding: 10px;
    border: 1px solid var(--accent);
    background: transparent;
    color: var(--accent);
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
  }
  #start-wave-btn:hover { background: var(--accent); color: var(--bg); }
  #start-wave-btn:disabled { opacity: 0.3; cursor: not-allowed; }

  /* Wave indicator */
  #wave-info { padding: 10px; font-size: 10px; color: var(--dim); }

  /* Speed control */
  #speed-btn {
    margin: 0 10px 10px;
    padding: 6px;
    border: 1px solid var(--accent2);
    background: transparent;
    color: var(--accent2);
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
  }
  #speed-btn:hover { background: var(--accent2); color: var(--bg); }

  /* ── OVERLAYS ── */
  .overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(5, 10, 15, 0.92);
    z-index: 100;
    backdrop-filter: blur(4px);
  }
  .overlay h2 {
    font-family: 'Orbitron', monospace;
    font-size: 36px;
    font-weight: 900;
    letter-spacing: 6px;
    margin-bottom: 16px;
  }
  .overlay p { color: var(--dim); font-size: 13px; letter-spacing: 2px; margin-bottom: 8px; }
  .overlay-btn {
    margin-top: 20px;
    padding: 12px 40px;
    border: 1px solid var(--accent);
    background: transparent;
    color: var(--accent);
    font-family: 'Orbitron', monospace;
    font-size: 14px;
    letter-spacing: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .overlay-btn:hover { background: var(--accent); color: var(--bg); }
  #win-overlay h2 { color: var(--accent3); text-shadow: 0 0 30px var(--accent3); }
  #lose-overlay h2 { color: var(--danger); text-shadow: 0 0 30px var(--danger); }
  #start-overlay h2 { color: var(--accent); text-shadow: 0 0 30px var(--accent); }
  #start-overlay .logo-sub {
    font-size: 11px; color: var(--dim); letter-spacing: 8px; margin-bottom: 30px;
  }
  .instructions { font-size: 10px; color: var(--dim); line-height: 1.8; text-align: center; margin-bottom: 10px; }
  .instructions span { color: var(--text); }
  #final-score { font-family: 'Orbitron', monospace; font-size: 22px; color: var(--gold); margin: 10px 0; }
</style>
</head>
<body>

<div id="header">
  <h1>IRON BASTION</h1>
  <div class="stat-block">
    <div class="stat"><span class="stat-label">LIVES</span><span class="stat-value" id="lives-val">20</span></div>
    <div class="stat"><span class="stat-label">GOLD</span><span class="stat-value" id="gold-val">150</span></div>
    <div class="stat"><span class="stat-label">WAVE</span><span class="stat-value" id="wave-val">0/20</span></div>
    <div class="stat"><span class="stat-label">SCORE</span><span class="stat-value" id="score-val">0</span></div>
  </div>
</div>

<div id="game-area">
  <div id="canvas-wrap">
    <canvas id="canvas"></canvas>

    <div class="overlay" id="start-overlay">
      <h2>IRON BASTION</h2>
      <div class="logo-sub">TOWER DEFENCE PROTOCOL</div>
      <div class="instructions">
        <p class="instructions">
          <span>Click</span> a tower to select it, then <span>click the map</span> to place.<br>
          <span>Right-click</span> or press <span>ESC</span> to deselect.<br>
          Towers cannot be placed on the path or other towers.<br>
          Survive all <span>20 waves</span> to win!
        </p>
      </div>
      <button class="overlay-btn" id="start-btn">DEPLOY</button>
    </div>

    <div class="overlay" id="win-overlay" style="display:none">
      <h2>VICTORY</h2>
      <p>ALL WAVES REPELLED</p>
      <div id="final-score">0</div>
      <button class="overlay-btn" id="restart-btn-win">PLAY AGAIN</button>
    </div>

    <div class="overlay" id="lose-overlay" style="display:none">
      <h2>BREACH</h2>
      <p>BASE HAS FALLEN</p>
      <div id="final-score-lose">0</div>
      <button class="overlay-btn" id="restart-btn-lose">RETRY</button>
    </div>
  </div>

  <div id="side-panel">
    <div class="panel-section">
      <div class="panel-title">// TOWERS</div>

      <div class="tower-card" data-type="gun" id="card-gun">
        <canvas class="tower-icon" id="icon-gun" width="28" height="28"></canvas>
        <div class="tower-info">
          <div class="tower-name">GUN</div>
          <div class="tower-cost">💰 75</div>
          <div class="tower-desc">Fast fire. Low dmg.</div>
        </div>
      </div>

      <div class="tower-card" data-type="cannon" id="card-cannon">
        <canvas class="tower-icon" id="icon-cannon" width="28" height="28"></canvas>
        <div class="tower-info">
          <div class="tower-name">CANNON</div>
          <div class="tower-cost">💰 125</div>
          <div class="tower-desc">Splash damage.</div>
        </div>
      </div>

      <div class="tower-card" data-type="laser" id="card-laser">
        <canvas class="tower-icon" id="icon-laser" width="28" height="28"></canvas>
        <div class="tower-info">
          <div class="tower-name">LASER</div>
          <div class="tower-cost">💰 200</div>
          <div class="tower-desc">Slow, high dmg.</div>
        </div>
      </div>

      <div class="tower-card" data-type="freeze" id="card-freeze">
        <canvas class="tower-icon" id="icon-freeze" width="28" height="28"></canvas>
        <div class="tower-info">
          <div class="tower-name">FREEZE</div>
          <div class="tower-cost">💰 150</div>
          <div class="tower-desc">Slows enemies.</div>
        </div>
      </div>

      <div class="tower-card" data-type="missile" id="card-missile">
        <canvas class="tower-icon" id="icon-missile" width="28" height="28"></canvas>
        <div class="tower-info">
          <div class="tower-name">MISSILE</div>
          <div class="tower-cost">💰 300</div>
          <div class="tower-desc">Big AoE. Slow fire.</div>
        </div>
      </div>
    </div>

    <div id="selected-info">
      <div class="panel-title">// SELECTED</div>
      <div class="info-row"><span>TYPE</span><span id="sel-type">—</span></div>
      <div class="info-row"><span>LEVEL</span><span id="sel-level">—</span></div>
      <div class="info-row"><span>DAMAGE</span><span id="sel-dmg">—</span></div>
      <div class="info-row"><span>RANGE</span><span id="sel-range">—</span></div>
      <div class="info-row"><span>KILLS</span><span id="sel-kills">—</span></div>
      <button id="upgrade-btn">⬆ UPGRADE</button>
      <button id="sell-btn">💰 SELL</button>
    </div>

    <div id="wave-info" id="wave-info-text"></div>

    <button id="start-wave-btn" disabled>START WAVE</button>
    <button id="speed-btn">⚡ SPEED: 1×</button>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════
// IRON BASTION — Full Tower Defence Game
// ═══════════════════════════════════════════════

const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
const COLS = 28, ROWS = 18, CELL = 40;

canvas.width  = COLS * CELL;
canvas.height = ROWS * CELL;

// ── PATH DEFINITION (grid cells) ──
const PATH_CELLS = [
  [0,4],[1,4],[2,4],[3,4],[4,4],[5,4],[5,5],[5,6],[5,7],[5,8],
  [5,9],[6,9],[7,9],[8,9],[9,9],[10,9],[11,9],[12,9],[12,8],[12,7],
  [12,6],[12,5],[12,4],[13,4],[14,4],[15,4],[16,4],[17,4],[17,5],
  [17,6],[17,7],[17,8],[17,9],[17,10],[17,11],[17,12],[17,13],
  [18,13],[19,13],[20,13],[21,13],[22,13],[22,12],[22,11],[22,10],
  [22,9],[22,8],[22,7],[22,6],[22,5],[22,4],[23,4],[24,4],[25,4],
  [26,4],[27,4]
];

// Build path set for quick lookup
const pathSet = new Set(PATH_CELLS.map(([c,r]) => `${c},${r}`));
function isPath(c,r) { return pathSet.has(`${c},${r}`); }

// ── TOWER DEFINITIONS ──
const TOWER_DEFS = {
  gun:     { name:'GUN',     cost:75,  dmg:12,  range:3.5, rate:0.8,  splash:0,   color:'#00d4ff', proj:'bullet', upgrades:[{dmg:20,range:4,rate:1.0},{dmg:32,range:4.5,rate:1.3}] },
  cannon:  { name:'CANNON',  cost:125, dmg:40,  range:3.0, rate:0.4,  splash:0.8, color:'#ff6b00', proj:'ball',   upgrades:[{dmg:65,range:3.5,rate:0.5,splash:1.0},{dmg:100,range:4,rate:0.65,splash:1.2}] },
  laser:   { name:'LASER',   cost:200, dmg:80,  range:4.5, rate:0.25, splash:0,   color:'#ff00ff', proj:'laser',  upgrades:[{dmg:140,range:5,rate:0.3},{dmg:220,range:5.5,rate:0.35}] },
  freeze:  { name:'FREEZE',  cost:150, dmg:5,   range:3.5, rate:0.5,  splash:1.0, color:'#88eeff', proj:'ice',    slow:0.5, upgrades:[{dmg:8,range:4,slow:0.3},{dmg:12,range:4.5,slow:0.2}] },
  missile: { name:'MISSILE', cost:300, dmg:180, range:5.0, rate:0.18, splash:1.8, color:'#ffd700', proj:'missile',upgrades:[{dmg:280,range:5.5,rate:0.22,splash:2.2},{dmg:420,range:6,rate:0.28,splash:2.8}] },
};

// ── ENEMY DEFINITIONS ──
const ENEMY_TYPES = {
  scout:   { name:'Scout',   hp:60,   speed:1.8, reward:8,  color:'#66ff88', size:8,  armor:0 },
  soldier: { name:'Soldier', hp:180,  speed:1.2, reward:15, color:'#ffaa22', size:10, armor:0 },
  tank:    { name:'Tank',    hp:600,  speed:0.7, reward:30, color:'#ff4444', size:14, armor:5 },
  speeder: { name:'Speeder', hp:90,   speed:3.0, reward:12, color:'#22ffff', size:7,  armor:0 },
  boss:    { name:'BOSS',    hp:3000, speed:0.6, reward:100,color:'#ff00ff', size:18, armor:15 },
  heavy:   { name:'Heavy',   hp:1200, speed:0.9, reward:50, color:'#ff8800', size:16, armor:10 },
};

// ── WAVE DEFINITIONS ──
const WAVES = [];
function makeWave(w) {
  const base = [
    {type:'scout',   count: Math.min(5+w*2,  20)},
    {type:'soldier', count: Math.max(0, w-2)*2},
    {type:'speeder', count: Math.max(0, w-3)*2},
    {type:'tank',    count: Math.max(0, w-5)},
    {type:'heavy',   count: Math.max(0, w-8)},
    {type:'boss',    count: w>=10 ? Math.floor((w-8)/2) : 0},
  ];
  return base.filter(e=>e.count>0);
}
for(let i=1; i<=20; i++) WAVES.push(makeWave(i));

// ── GAME STATE ──
let G = {};
let animId = null;
let gameSpeed = 1;

function initGame() {
  G = {
    lives: 20,
    gold: 150,
    score: 0,
    wave: 0,
    waveActive: false,
    gameOver: false,
    won: false,
    towers: [],
    enemies: [],
    projectiles: [],
    particles: [],
    floaters: [],
    selectedTowerType: null,
    selectedTower: null,
    hoverCell: null,
    spawnQueue: [],
    spawnTimer: 0,
    lastTime: 0,
  };
  updateUI();
  document.getElementById('start-wave-btn').disabled = false;
  document.getElementById('selected-info').classList.remove('visible');
}

// ── UTILITY ──
function dist(a, b) { return Math.hypot(a.x-b.x, a.y-b.y); }
function cellCenter(c,r) { return { x: c*CELL+CELL/2, y: r*CELL+CELL/2 }; }

// ── UI UPDATES ──
function updateUI() {
  document.getElementById('lives-val').textContent = G.lives;
  document.getElementById('gold-val').textContent  = G.gold;
  document.getElementById('wave-val').textContent  = `${G.wave}/20`;
  document.getElementById('score-val').textContent = G.score;
  // tower card affordability
  for(const [type, def] of Object.entries(TOWER_DEFS)) {
    const card = document.getElementById(`card-${type}`);
    card.classList.toggle('too-expensive', G.gold < def.cost);
  }
}

function updateSelectedInfo() {
  const t = G.selectedTower;
  const info = document.getElementById('selected-info');
  if(!t) { info.classList.remove('visible'); return; }
  info.classList.add('visible');
  const def = TOWER_DEFS[t.type];
  const upg = def.upgrades[t.level-1];
  document.getElementById('sel-type').textContent  = def.name;
  document.getElementById('sel-level').textContent = `${t.level}/3`;
  document.getElementById('sel-dmg').textContent   = t.dmg;
  document.getElementById('sel-range').textContent = t.range.toFixed(1);
  document.getElementById('sel-kills').textContent = t.kills || 0;
  const upgBtn = document.getElementById('upgrade-btn');
  const upgCost = t.level < 3 ? Math.round(def.cost * 0.8 * t.level) : 0;
  upgBtn.textContent = t.level < 3 ? `⬆ UPGRADE (${upgCost}g)` : '✓ MAX LEVEL';
  upgBtn.disabled = t.level >= 3 || G.gold < upgCost;
  const sellVal = Math.round(def.cost * 0.6 * t.level);
  document.getElementById('sell-btn').textContent = `💰 SELL (${sellVal}g)`;
}

// ── TOWER CREATION ──
function createTower(type, col, row) {
  const def = TOWER_DEFS[type];
  return {
    id: Math.random(),
    type, col, row,
    x: col*CELL+CELL/2,
    y: row*CELL+CELL/2,
    dmg: def.dmg,
    range: def.range,
    rate: def.rate,
    splash: def.splash || 0,
    slow: def.slow || 0,
    color: def.color,
    level: 1,
    cooldown: 0,
    kills: 0,
    angle: 0,
  };
}

function upgradeTower(t) {
  const def = TOWER_DEFS[t.type];
  if(t.level >= 3) return;
  const cost = Math.round(def.cost * 0.8 * t.level);
  if(G.gold < cost) return;
  G.gold -= cost;
  t.level++;
  const upg = def.upgrades[t.level-2];
  if(upg.dmg)    t.dmg    = upg.dmg;
  if(upg.range)  t.range  = upg.range;
  if(upg.rate)   t.rate   = upg.rate;
  if(upg.splash) t.splash = upg.splash;
  if(upg.slow)   t.slow   = upg.slow;
  spawnParticles(t.x, t.y, 10, '#ffd700', 3);
  updateUI();
  updateSelectedInfo();
}

function sellTower(t) {
  const def = TOWER_DEFS[t.type];
  const val = Math.round(def.cost * 0.6 * t.level);
  G.gold += val;
  addFloater(`+${val}g`, t.x, t.y, '#ffd700');
  G.towers = G.towers.filter(x=>x!==t);
  G.selectedTower = null;
  updateUI();
  updateSelectedInfo();
}

// ── ENEMY CREATION ──
function createEnemy(type) {
  const def = ENEMY_TYPES[type];
  const hp = def.hp;
  const start = PATH_CELLS[0];
  return {
    id: Math.random(),
    type, hp, maxHp: hp,
    speed: def.speed,
    reward: def.reward,
    color: def.color,
    size: def.size,
    armor: def.armor || 0,
    x: start[0]*CELL+CELL/2,
    y: start[1]*CELL+CELL/2,
    pathIndex: 0,
    slow: 1,
    slowTimer: 0,
    dead: false,
    reachedEnd: false,
  };
}

// ── WAVE SPAWNING ──
function startWave() {
  if(G.waveActive || G.wave >= 20) return;
  G.wave++;
  G.waveActive = true;
  document.getElementById('start-wave-btn').disabled = true;
  document.getElementById('wave-val').textContent = `${G.wave}/20`;

  const waveDef = WAVES[G.wave-1];
  G.spawnQueue = [];
  for(const {type, count} of waveDef) {
    for(let i=0; i<count; i++) {
      G.spawnQueue.push(type);
    }
  }
  // Shuffle
  for(let i=G.spawnQueue.length-1; i>0; i--) {
    const j = Math.floor(Math.random()*(i+1));
    [G.spawnQueue[i],G.spawnQueue[j]] = [G.spawnQueue[j],G.spawnQueue[i]];
  }
  G.spawnTimer = 0;
}

// ── PARTICLES & FLOATERS ──
function spawnParticles(x, y, count, color, speed=2) {
  for(let i=0; i<count; i++) {
    const angle = Math.random()*Math.PI*2;
    const spd   = (0.5+Math.random())*speed;
    G.particles.push({ x, y, vx: Math.cos(angle)*spd, vy: Math.sin(angle)*spd, life:1, color, size: 2+Math.random()*3 });
  }
}

function addFloater(text, x, y, color='#ffffff') {
  G.floaters.push({ text, x, y, vy:-1.5, life:1, color });
}

// ── PROJECTILE CREATION ──
function fireAt(tower, enemy) {
  const proj = {
    id: Math.random(),
    type: TOWER_DEFS[tower.type].proj,
    x: tower.x,
    y: tower.y,
    tx: enemy.x,
    ty: enemy.y,
    target: enemy,
    tower,
    speed: tower.type==='laser' ? 999 : (tower.type==='missile' ? 6 : 12),
    color: tower.color,
    hit: false,
    splash: tower.splash,
    slow: tower.slow,
  };
  G.projectiles.push(proj);
}

// ── MAIN UPDATE ──
function update(dt) {
  if(G.gameOver || G.won) return;
  dt = Math.min(dt, 0.1); // cap delta

  // Spawn enemies
  if(G.waveActive && G.spawnQueue.length > 0) {
    G.spawnTimer -= dt;
    if(G.spawnTimer <= 0) {
      G.enemies.push(createEnemy(G.spawnQueue.shift()));
      G.spawnTimer = 0.5 / gameSpeed * (1/gameSpeed); // space out
      G.spawnTimer = 0.7;
    }
  }

  // Move enemies
  for(const e of G.enemies) {
    if(e.dead || e.reachedEnd) continue;
    if(e.slowTimer > 0) e.slowTimer -= dt;
    const slowMult = e.slowTimer > 0 ? e.slow : 1;
    const spd = e.speed * CELL * dt * slowMult;

    const target = PATH_CELLS[e.pathIndex+1];
    if(!target) { e.reachedEnd = true; G.lives--; updateUI(); continue; }

    const tx = target[0]*CELL+CELL/2;
    const ty = target[1]*CELL+CELL/2;
    const d  = Math.hypot(tx-e.x, ty-e.y);
    if(d < spd) {
      e.x = tx; e.y = ty; e.pathIndex++;
    } else {
      e.x += (tx-e.x)/d*spd;
      e.y += (ty-e.y)/d*spd;
    }
  }

  // Towers shoot
  for(const t of G.towers) {
    t.cooldown -= dt;
    if(t.cooldown > 0) continue;

    // Find target: first enemy in range (furthest along path)
    let bestEnemy = null, bestIdx = -1;
    for(const e of G.enemies) {
      if(e.dead || e.reachedEnd) continue;
      if(dist(t, e) <= t.range * CELL && e.pathIndex > bestIdx) {
        bestEnemy = e; bestIdx = e.pathIndex;
      }
    }
    if(bestEnemy) {
      t.angle = Math.atan2(bestEnemy.y-t.y, bestEnemy.x-t.x);
      if(t.type === 'laser') {
        // Instant hit
        dealDamage(t, bestEnemy, true);
      } else {
        fireAt(t, bestEnemy);
      }
      t.cooldown = 1/t.rate;
    }
  }

  // Move projectiles
  for(const p of G.projectiles) {
    if(p.hit) continue;
    if(p.target.dead) { p.hit = true; continue; }
    const tx = p.target.x, ty = p.target.y;
    const d  = Math.hypot(tx-p.x, ty-p.y);
    if(d < p.speed*dt*60) {
      p.x = tx; p.y = ty; p.hit = true;
      dealDamage(p.tower, p.target, false, p.splash, p.slow);
    } else {
      p.x += (tx-p.x)/d*p.speed*dt*60;
      p.y += (ty-p.y)/d*p.speed*dt*60;
    }
  }

  // Update particles
  for(const p of G.particles) {
    p.x += p.vx; p.y += p.vy;
    p.vy += 0.08;
    p.life -= dt * 2;
  }
  G.particles = G.particles.filter(p=>p.life>0);

  // Update floaters
  for(const f of G.floaters) {
    f.y += f.vy;
    f.life -= dt * 1.5;
  }
  G.floaters = G.floaters.filter(f=>f.life>0);

  // Cleanup
  G.projectiles = G.projectiles.filter(p=>!p.hit);
  G.enemies = G.enemies.filter(e=>!e.dead && !e.reachedEnd);

  // Check wave end
  if(G.waveActive && G.spawnQueue.length===0 && G.enemies.length===0) {
    G.waveActive = false;
    if(G.wave >= 20) {
      G.won = true;
      document.getElementById('win-overlay').style.display='flex';
      document.getElementById('final-score').textContent = `SCORE: ${G.score}`;
    } else {
      document.getElementById('start-wave-btn').disabled = false;
      // Bonus gold per wave
      const bonus = 20 + G.wave*5;
      G.gold += bonus;
      addFloater(`+${bonus}g WAVE BONUS`, canvas.width/2, canvas.height/2, '#ffd700');
      updateUI();
    }
  }

  // Lives check
  if(G.lives <= 0) {
    G.lives = 0; G.gameOver = true;
    document.getElementById('lose-overlay').style.display='flex';
    document.getElementById('final-score-lose').textContent = `SCORE: ${G.score}`;
    updateUI();
  }
}

function dealDamage(tower, enemy, isLaser, splash=0, slow=0) {
  let actualDmg = Math.max(1, tower.dmg - enemy.armor);
  if(isLaser) {
    spawnParticles(enemy.x, enemy.y, 3, tower.color, 2);
  }

  const hitEnemies = new Set();
  hitEnemies.add(enemy);

  if(splash > 0) {
    for(const e of G.enemies) {
      if(e.dead) continue;
      if(dist({x:enemy.x,y:enemy.y}, e) < splash * CELL) hitEnemies.add(e);
    }
    spawnParticles(enemy.x, enemy.y, 12, tower.color, 4);
  } else {
    spawnParticles(enemy.x, enemy.y, 4, tower.color, 2);
  }

  for(const e of hitEnemies) {
    const dmg = e===enemy ? actualDmg : Math.round(actualDmg*0.5);
    e.hp -= dmg;
    if(slow > 0) { e.slow = slow; e.slowTimer = 1.5; }
    if(e.hp <= 0) {
      e.dead = true;
      tower.kills = (tower.kills||0)+1;
      G.score += e.reward * G.wave;
      G.gold  += e.reward;
      addFloater(`+${e.reward}g`, e.x, e.y, '#ffd700');
      spawnParticles(e.x, e.y, 15, e.color, 3);
      updateUI();
    }
  }
}

// ── DRAWING ──
function draw() {
  ctx.fillStyle = '#07111a';
  ctx.fillRect(0,0,canvas.width,canvas.height);

  drawGrid();
  drawPath();
  drawTowers();
  drawEnemies();
  drawProjectiles();
  drawParticles();
  drawFloaters();
  drawPlacementPreview();
}

function drawGrid() {
  ctx.strokeStyle = 'rgba(26,58,92,0.3)';
  ctx.lineWidth = 0.5;
  for(let c=0; c<=COLS; c++) {
    ctx.beginPath(); ctx.moveTo(c*CELL,0); ctx.lineTo(c*CELL,canvas.height); ctx.stroke();
  }
  for(let r=0; r<=ROWS; r++) {
    ctx.beginPath(); ctx.moveTo(0,r*CELL); ctx.lineTo(canvas.width,r*CELL); ctx.stroke();
  }
}

function drawPath() {
  // Path background
  for(const [c,r] of PATH_CELLS) {
    ctx.fillStyle = '#0a1e30';
    ctx.fillRect(c*CELL, r*CELL, CELL, CELL);
  }
  // Path lines
  ctx.strokeStyle = 'rgba(0,180,255,0.25)';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(PATH_CELLS[0][0]*CELL+CELL/2, PATH_CELLS[0][1]*CELL+CELL/2);
  for(const [c,r] of PATH_CELLS) ctx.lineTo(c*CELL+CELL/2, r*CELL+CELL/2);
  ctx.stroke();

  // Start & End markers
  const s = PATH_CELLS[0], e = PATH_CELLS[PATH_CELLS.length-1];
  ctx.fillStyle = '#00ff88';
  ctx.font = '10px Orbitron'; ctx.textAlign='center';
  ctx.fillText('▶', s[0]*CELL+CELL/2, s[1]*CELL+CELL/2+4);
  ctx.fillStyle = '#ff2244';
  ctx.fillText('⬡', e[0]*CELL+CELL/2, e[1]*CELL+CELL/2+4);
}

function drawTowers() {
  for(const t of G.towers) {
    const cx = t.x, cy = t.y;
    const isSelected = G.selectedTower === t;

    // Range ring if selected
    if(isSelected) {
      ctx.beginPath();
      ctx.arc(cx, cy, t.range*CELL, 0, Math.PI*2);
      ctx.strokeStyle = 'rgba(0,212,255,0.3)';
      ctx.lineWidth = 1;
      ctx.setLineDash([4,4]);
      ctx.stroke();
      ctx.setLineDash([]);
    }

    // Tower base
    ctx.save();
    ctx.translate(cx, cy);

    const sz = 14 + t.level*2;
    // Base platform
    ctx.fillStyle = '#0d2035';
    ctx.strokeStyle = isSelected ? t.color : 'rgba(0,212,255,0.4)';
    ctx.lineWidth = isSelected ? 2 : 1;
    ctx.beginPath();
    ctx.rect(-sz/2, -sz/2, sz, sz);
    ctx.fill(); ctx.stroke();

    // Level pips
    for(let i=0; i<t.level; i++) {
      ctx.fillStyle = t.color;
      ctx.fillRect(-sz/2 + i*(sz/3)+2, sz/2+2, sz/3-2, 3);
    }

    // Barrel (rotates)
    ctx.rotate(t.angle);
    ctx.fillStyle = t.color;
    ctx.shadowColor = t.color;
    ctx.shadowBlur = isSelected ? 12 : 6;

    if(t.type==='gun') {
      ctx.fillRect(-2, -10, 4, 10);
      ctx.beginPath(); ctx.arc(0,0,6,0,Math.PI*2); ctx.fill();
    } else if(t.type==='cannon') {
      ctx.fillRect(-3, -12, 6, 12);
      ctx.beginPath(); ctx.arc(0,0,8,0,Math.PI*2); ctx.fill();
    } else if(t.type==='laser') {
      ctx.fillRect(-1, -13, 2, 13);
      ctx.fillRect(-2, -16, 4, 3);
      ctx.beginPath(); ctx.arc(0,0,5,0,Math.PI*2); ctx.fill();
    } else if(t.type==='freeze') {
      for(let a=0; a<6; a++) {
        ctx.save(); ctx.rotate(a*Math.PI/3);
        ctx.fillRect(-1, -10, 2, 10);
        ctx.restore();
      }
    } else if(t.type==='missile') {
      ctx.fillRect(-4, -14, 8, 14);
      ctx.beginPath();
      ctx.moveTo(0,-18); ctx.lineTo(4,-14); ctx.lineTo(-4,-14);
      ctx.fill();
      ctx.beginPath(); ctx.arc(0,0,7,0,Math.PI*2); ctx.fill();
    }

    ctx.shadowBlur = 0;
    ctx.restore();
  }
}

function drawEnemies() {
  for(const e of G.enemies) {
    const x=e.x, y=e.y, s=e.size;
    ctx.save();

    // Shadow
    ctx.beginPath();
    ctx.ellipse(x, y+s, s*0.8, s*0.3, 0, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(0,0,0,0.4)';
    ctx.fill();

    // Body
    ctx.fillStyle = e.slowTimer>0 ? '#88eeff' : e.color;
    ctx.shadowColor = e.color;
    ctx.shadowBlur = 8;
    if(e.type==='boss' || e.type==='heavy') {
      ctx.fillRect(x-s,y-s,s*2,s*2);
    } else if(e.type==='speeder') {
      ctx.beginPath();
      ctx.moveTo(x, y-s); ctx.lineTo(x+s, y+s); ctx.lineTo(x-s, y+s);
      ctx.fill();
    } else {
      ctx.beginPath(); ctx.arc(x, y, s, 0, Math.PI*2); ctx.fill();
    }
    ctx.shadowBlur = 0;

    // HP bar
    const bw=s*2.5, bh=3;
    const bx=x-bw/2, by=y-s-7;
    ctx.fillStyle = '#1a1a1a';
    ctx.fillRect(bx, by, bw, bh);
    const pct = e.hp/e.maxHp;
    ctx.fillStyle = pct>0.6 ? '#00ff88' : pct>0.3 ? '#ffaa00' : '#ff2244';
    ctx.fillRect(bx, by, bw*pct, bh);

    ctx.restore();
  }
}

function drawProjectiles() {
  for(const p of G.projectiles) {
    ctx.save();
    ctx.beginPath();
    if(p.type==='missile') {
      ctx.arc(p.x, p.y, 5, 0, Math.PI*2);
      ctx.fillStyle = p.color;
      ctx.shadowColor = p.color; ctx.shadowBlur = 10;
      ctx.fill();
    } else if(p.type==='ball') {
      ctx.arc(p.x, p.y, 5, 0, Math.PI*2);
      ctx.fillStyle = p.color;
      ctx.shadowColor = p.color; ctx.shadowBlur = 8;
      ctx.fill();
    } else if(p.type==='ice') {
      ctx.arc(p.x, p.y, 4, 0, Math.PI*2);
      ctx.fillStyle = '#88eeff';
      ctx.shadowColor = '#88eeff'; ctx.shadowBlur = 8;
      ctx.fill();
    } else {
      ctx.arc(p.x, p.y, 3, 0, Math.PI*2);
      ctx.fillStyle = p.color;
      ctx.shadowColor = p.color; ctx.shadowBlur = 6;
      ctx.fill();
    }
    ctx.shadowBlur = 0;
    ctx.restore();
  }
}

function drawParticles() {
  for(const p of G.particles) {
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI*2);
    ctx.fillStyle = p.color + Math.round(p.life*255).toString(16).padStart(2,'0');
    ctx.fill();
  }
}

function drawFloaters() {
  for(const f of G.floaters) {
    ctx.globalAlpha = f.life;
    ctx.fillStyle = f.color;
    ctx.font = 'bold 11px Share Tech Mono';
    ctx.textAlign = 'center';
    ctx.fillText(f.text, f.x, f.y);
  }
  ctx.globalAlpha = 1;
}

function drawPlacementPreview() {
  if(!G.selectedTowerType || !G.hoverCell) return;
  const [c,r] = G.hoverCell;
  const valid = !isPath(c,r) && !G.towers.find(t=>t.col===c&&t.row===r);
  ctx.fillStyle = valid ? 'rgba(0,212,255,0.2)' : 'rgba(255,34,68,0.2)';
  ctx.strokeStyle = valid ? '#00d4ff' : '#ff2244';
  ctx.lineWidth = 2;
  ctx.fillRect(c*CELL, r*CELL, CELL, CELL);
  ctx.strokeRect(c*CELL, r*CELL, CELL, CELL);

  if(valid) {
    // Range preview
    const def = TOWER_DEFS[G.selectedTowerType];
    ctx.beginPath();
    ctx.arc(c*CELL+CELL/2, r*CELL+CELL/2, def.range*CELL, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(0,212,255,0.25)';
    ctx.setLineDash([4,4]);
    ctx.stroke();
    ctx.setLineDash([]);
  }
}

// ── GAME LOOP ──
let lastTimestamp = 0;
function loop(ts) {
  const rawDt = Math.min((ts - lastTimestamp)/1000, 0.1);
  lastTimestamp = ts;
  const dt = rawDt * gameSpeed;

  update(dt);
  draw();
  animId = requestAnimationFrame(loop);
}

// ── INPUT ──
canvas.addEventListener('mousemove', e => {
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.width / rect.width;
  const scaleY = canvas.height / rect.height;
  const mx = (e.clientX - rect.left) * scaleX;
  const my = (e.clientY - rect.top)  * scaleY;
  G.hoverCell = [Math.floor(mx/CELL), Math.floor(my/CELL)];
});

canvas.addEventListener('mouseleave', () => { G.hoverCell = null; });

canvas.addEventListener('click', e => {
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.width / rect.width;
  const scaleY = canvas.height / rect.height;
  const mx = (e.clientX - rect.left) * scaleX;
  const my = (e.clientY - rect.top)  * scaleY;
  const col = Math.floor(mx/CELL);
  const row = Math.floor(my/CELL);

  if(G.selectedTowerType) {
    // Try to place tower
    if(!isPath(col,row) && !G.towers.find(t=>t.col===col&&t.row===row)) {
      const def = TOWER_DEFS[G.selectedTowerType];
      if(G.gold >= def.cost) {
        G.gold -= def.cost;
        G.towers.push(createTower(G.selectedTowerType, col, row));
        spawnParticles(col*CELL+CELL/2, row*CELL+CELL/2, 8, def.color, 2);
        updateUI();
      }
    }
  } else {
    // Select tower
    const hit = G.towers.find(t=>Math.abs(t.col-col)<=0 && Math.abs(t.row-row)<=0);
    G.selectedTower = hit || null;
    updateSelectedInfo();
  }
});

canvas.addEventListener('contextmenu', e => {
  e.preventDefault();
  G.selectedTowerType = null;
  G.selectedTower = null;
  document.querySelectorAll('.tower-card').forEach(c=>c.classList.remove('selected'));
  updateSelectedInfo();
});

document.querySelectorAll('.tower-card').forEach(card => {
  card.addEventListener('click', () => {
    const type = card.dataset.type;
    if(G.gold < TOWER_DEFS[type].cost) return;
    if(G.selectedTowerType === type) {
      G.selectedTowerType = null;
      card.classList.remove('selected');
    } else {
      G.selectedTowerType = type;
      G.selectedTower = null;
      updateSelectedInfo();
      document.querySelectorAll('.tower-card').forEach(c=>c.classList.remove('selected'));
      card.classList.add('selected');
    }
  });
});

document.addEventListener('keydown', e => {
  if(e.key==='Escape') {
    G.selectedTowerType = null;
    G.selectedTower = null;
    document.querySelectorAll('.tower-card').forEach(c=>c.classList.remove('selected'));
    updateSelectedInfo();
  }
});

document.getElementById('start-wave-btn').addEventListener('click', startWave);

document.getElementById('speed-btn').addEventListener('click', () => {
  gameSpeed = gameSpeed===1 ? 2 : gameSpeed===2 ? 3 : 1;
  document.getElementById('speed-btn').textContent = `⚡ SPEED: ${gameSpeed}×`;
});

document.getElementById('upgrade-btn').addEventListener('click', () => {
  if(G.selectedTower) upgradeTower(G.selectedTower);
});

document.getElementById('sell-btn').addEventListener('click', () => {
  if(G.selectedTower) sellTower(G.selectedTower);
});

function restartGame() {
  document.getElementById('win-overlay').style.display='none';
  document.getElementById('lose-overlay').style.display='none';
  if(animId) cancelAnimationFrame(animId);
  initGame();
  lastTimestamp = performance.now();
  animId = requestAnimationFrame(loop);
}

document.getElementById('restart-btn-win').addEventListener('click', restartGame);
document.getElementById('restart-btn-lose').addEventListener('click', restartGame);

document.getElementById('start-btn').addEventListener('click', () => {
  document.getElementById('start-overlay').style.display='none';
  restartGame();
});

// ── DRAW TOWER ICONS in side panel ──
function drawTowerIcon(canvasId, type) {
  const ic = document.getElementById(canvasId);
  if(!ic) return;
  const c = ic.getContext('2d');
  const def = TOWER_DEFS[type];
  c.clearRect(0,0,28,28);
  c.fillStyle = '#0d2035';
  c.fillRect(0,0,28,28);

  c.save();
  c.translate(14,14);
  c.fillStyle = def.color;
  c.shadowColor = def.color;
  c.shadowBlur = 8;

  if(type==='gun') {
    c.fillRect(-2,-9,4,9); c.beginPath(); c.arc(0,0,5,0,Math.PI*2); c.fill();
  } else if(type==='cannon') {
    c.fillRect(-3,-10,6,10); c.beginPath(); c.arc(0,0,6,0,Math.PI*2); c.fill();
  } else if(type==='laser') {
    c.fillRect(-1,-11,2,11); c.fillRect(-2,-13,4,3); c.beginPath(); c.arc(0,0,4,0,Math.PI*2); c.fill();
  } else if(type==='freeze') {
    for(let a=0; a<6; a++) { c.save(); c.rotate(a*Math.PI/3); c.fillRect(-1,-9,2,9); c.restore(); }
  } else if(type==='missile') {
    c.fillRect(-3,-11,6,11); c.beginPath(); c.moveTo(0,-14); c.lineTo(3,-11); c.lineTo(-3,-11); c.fill();
    c.beginPath(); c.arc(0,0,5,0,Math.PI*2); c.fill();
  }
  c.shadowBlur=0; c.restore();
}

for(const type of Object.keys(TOWER_DEFS)) {
  drawTowerIcon(`icon-${type}`, type);
}

// Initial state
updateUI();

// ── CANVAS SCALING ──
function resizeCanvas() {
  const wrap = document.getElementById('canvas-wrap');
  const maxW = wrap.clientWidth - 20;
  const maxH = wrap.clientHeight - 20;
  const scale = Math.min(maxW/(COLS*CELL), maxH/(ROWS*CELL));
  canvas.style.width  = (COLS*CELL*scale)+'px';
  canvas.style.height = (ROWS*CELL*scale)+'px';
}
window.addEventListener('resize', resizeCanvas);
resizeCanvas();
</script>
